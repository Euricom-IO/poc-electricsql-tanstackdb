# Shared configuration for the API and the db package.
# Copy to `.env` (bun and drizzle-kit load it automatically when run from the repo root).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/todoapp
JWT_SECRET=dev-secret-change-me
API_PORT=3000
# Consumed by the web dev server / vite proxy target
VITE_API_URL=http://localhost:3000
